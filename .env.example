# Copy to `.env` for local defaults (`.env` is gitignored).
# Use Makefile assignment syntax: VAR=value, one per line, no spaces around `=`.

# Optional: push/pull namespace (e.g. dilshodm → dilshodm/gcc-builder:1, dilshodm/python-builder:1).
# DOCKER_USER=dilshodm

# Linux platform for toolchain compile + builder images (host binaries inside Docker).
# Auto: matches your machine (e.g. Apple Silicon → linux/arm64). Set to cross-build:
#   DOCKER_HOST_PLATFORM=linux/amd64   # x86_64 toolchains + builders (e.g. run on Intel/AMD hosts)
#   DOCKER_HOST_PLATFORM=linux/arm64   # AArch64 toolchains + builders
# Requires Docker buildx / QEMU when it differs from the daemon’s native arch.

# Optional overrides (defaults are in the Makefile):
# BINUTILS_VERSION=2.45
# GCC_VERSION=16.1.0
# Ubuntu LTS for toolchain compile + builder (must match across both; default 24.04).
# HOST_UBUNTU=24.04
